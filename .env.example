# ──────────────────────────────────────────────────────────────────────────────
# .env.example — Copia este archivo como ".env" y rellena los valores reales
# NUNCA subas el .env real a Git
# ──────────────────────────────────────────────────────────────────────────────

# ── Mercado Libre App ─────────────────────────────────────────────────────────
# Obtén estos valores en: https://developers.mercadolibre.cl/apps
MELI_CLIENT_ID=TU_APP_ID_AQUI
MELI_CLIENT_SECRET=TU_APP_SECRET_AQUI
MELI_REDIRECT_URI=https://tu-dominio.com/auth/callback

# Secret para validar firma de webhooks (configúralo en el portal ML)
# Puede ser cualquier string aleatorio: openssl rand -hex 32
MELI_WEBHOOK_SECRET=

# ── Base de Datos ─────────────────────────────────────────────────────────────
# Desarrollo (SQLite — no requiere configuración extra):
DATABASE_URL=sqlite+aiosqlite:///./data/divinittys_agent.db

# Producción (PostgreSQL — descomenta y configura):
# DATABASE_URL=postgresql+asyncpg://divinittys:TU_PASSWORD@postgres:5432/divinittys
# POSTGRES_PASSWORD=TU_PASSWORD_SEGURA

# ── Notificaciones Telegram ───────────────────────────────────────────────────
# Crea un bot con @BotFather y obtén el token
TELEGRAM_BOT_TOKEN=
# Obtén tu chat_id enviando un mensaje al bot y consultando:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# ── Datos Bancarios (van en el mensaje al comprador) ─────────────────────────
BANK_NAME=Banco Estado
BANK_ACCOUNT_TYPE=Cuenta Corriente
BANK_ACCOUNT_NUMBER=000000000
BANK_RUT=12.345.678-9
BANK_OWNER=Nombre Titular Divinittys
BANK_EMAIL=rekkiem@gmail.com

# ── Costo de Envío BlueExpress (en pesos CLP sin puntos) ─────────────────────
SHIPPING_COST=4000

# ── Configuración del Agente ──────────────────────────────────────────────────
POLLING_INTERVAL_MINUTES=5
POLLING_LOOKBACK_HOURS=2
ENVIRONMENT=production
DEBUG=false
