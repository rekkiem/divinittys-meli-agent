# .env.debug — Variables para testing local con el mock server
# Apunta la API de ML al servidor mock local (no se necesitan credenciales reales)
#
# USO:
#   cp .env.debug .env    (solo para debug, NO subir a Git ni usar en producción)

# ── Mock ML API ───────────────────────────────────────────────────────────────
MELI_CLIENT_ID=debug_client_id_12345
MELI_CLIENT_SECRET=debug_secret_abc
MELI_REDIRECT_URI=http://localhost:8000/auth/callback

# ← CLAVE: apunta al mock server local en vez de api.mercadolibre.com
MELI_API_BASE=http://localhost:9999
MELI_AUTH_BASE=http://localhost:9999

MELI_WEBHOOK_SECRET=
MELI_SELLER_ID=111222333

# ── Base de datos (SQLite local) ──────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/debug_agent.db

# ── Telegram desactivado en debug (notificaciones solo en consola) ────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Datos bancarios de prueba ─────────────────────────────────────────────────
BANK_NAME=Banco de Pruebas
BANK_ACCOUNT_TYPE=Cuenta Corriente
BANK_ACCOUNT_NUMBER=123456789
BANK_RUT=11.111.111-1
BANK_OWNER=Test Divinittys
BANK_EMAIL=rekkiem@gmail.com
SHIPPING_COST=4000

# ── Admin panel sin auth en debug ─────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=debug1234
ADMIN_ALLOWED_IPS=

# ── Config del agente ─────────────────────────────────────────────────────────
POLLING_INTERVAL_MINUTES=1
POLLING_LOOKBACK_HOURS=24
ENVIRONMENT=development
DEBUG=true
